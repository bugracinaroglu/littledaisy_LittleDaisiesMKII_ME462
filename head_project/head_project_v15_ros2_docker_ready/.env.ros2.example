# Use the same ROS distribution and domain ID on the Raspberry Pi and remote PC.
ROS_DISTRO=jazzy
ROS_DOMAIN_ID=42
ROS_AUTOMATIC_DISCOVERY_RANGE=SUBNET
RMW_IMPLEMENTATION=rmw_fastrtps_cpp

# The container uses host networking and reaches the Pi OS application locally.
ROBOT_HEAD_BRIDGE_HOST=127.0.0.1
ROBOT_HEAD_BRIDGE_PORT=8765
ROBOT_HEAD_AUTO_SWITCH_TO_ROS=true

# For different routed networks/VPNs where multicast discovery does not work,
# set a Fast DDS Discovery Server address and use compose.ros2.discovery.yaml.
# Example: ROS_DISCOVERY_SERVER=192.168.1.50:11811
# ROS_DISCOVERY_SERVER=
